                    <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"></path>
                </svg>
            </a> -->
        </div>
    </div>

    <aside class="text-center mt-6 opacity-70 text-sm flex flex-col sm:flex-row justify-center gap-2 sm:gap-4">
        <p>© {currentYear} Proxi'Clean Services - Tous droits réservés.</p>
        <span class="hidden sm:inline">|</span>
        <a href="mailto:oufrid31@outlook.fr?subject=Contact%20depuis%20le%20site%20Proxiclean-Service" class="hover:text-secondaryTheme transition-colors">
            Réalisation : <span class="font-bold hover:underline inline-flex items-center gap-1.5 transition-all">wilbou.dev</span>

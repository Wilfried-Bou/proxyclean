---
import { Image } from "astro:assets";
import logo from '../assets/logo2.png';

const currentYear = new Date().getFullYear();
---

<footer class="bg-base-200 text-base-content p-10">
    <div class="footer sm:footer-horizontal flex flex-col items-center text-center sm:grid sm:text-left sm:items-start max-w-6xl mx-auto">
        <aside class="flex flex-col items-center">
            <a href="/">
                <Image 
                    src={logo}
                    alt="Proxi'Clean Services - Entreprise de nettoyage professionnel à Toulouse"
                    width={150}
                    height={150}
                    class="w-full h-full object-contain"
                    loading="lazy" 
                />
            </a>
        </aside>

        <nav class="flex flex-col items-center sm:items-start">
            <h6 class="footer-title">Nos Services</h6>
            <a href="/entretien" class="link link-hover">Entretien régulier</a>
            <a href="/specifique" class="link link-hover">Prestations spécifiques</a>
        </nav>

        <nav class="flex flex-col items-center sm:items-start">
            <h6 class="footer-title">L'entreprise</h6>
            <a href="/contact" class="link link-hover">Contact</a>
            <a href="/rejoindre" class="link link-hover">Rejoignez-nous</a>
        </nav> 

        <nav class="flex flex-col items-center sm:items-start">
            <h6 class="footer-title">Informations</h6> 
            <a href="/mentions-legales" class="link link-hover">Mentions légales</a>
            <a href="/politique" class="link link-hover">Politique de confidentialité</a>
        </nav>
    </div>
    
    <!-- EMPLACEMENT RESEAUX SOCIAUX -->
    <div class="flex flex-col items-center mt-6">
        <h6 class="footer-title">Nous suivre</h6>
        
        <div class="flex justify-center gap-6 mt-4 pb-6 border-b border-base-300 w-full max-w-xs">

            <!-- LINKEDIN -->
            <a href="https://www.linkedin.com/company/proxi-clean-services/posts/?feedView=all" 
                target="_blank" 
                rel="noopener noreferrer" 
                class="hover:scale-150 transition-transform duration-300 inline-block" 
                aria-label="Suivez Proxi'Clean sur LinkedIn">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="#0A66C2">
                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
            </a>


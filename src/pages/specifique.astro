---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { Image } from 'astro:assets';

import nuisible from "../assets/specifique/nuisible.jpg";
import diogene from "../assets/specifique/diogene.jpg";
import panneaux from "../assets/specifique/panneaux.jpg";
import travaux from "../assets/specifique/travaux.jpg";
import vitrerie from "../assets/specifique/vitrerie.jpg";
---
<Layout title="Nettoyage Spécifique | Proxi'Clean Services" 
        description="Nettoyage après travaux, vitrerie haute hauteur, remise en état et protocoles sanitaires spéciaux à Toulouse et en Occitanie.">

    <Breadcrumb currentPage="Prestations spécifiques"></Breadcrumb>    
    
    <section class="py-16 bg-primaryTheme text-white text-center">
    <h1 class="text-4xl md:text-6xl font-black text-white uppercase leading-tight">
			Prestations <span class="text-secondaryTheme">spécifiques</span>
		</h1>
    <div class="w-24 h-1.5 bg-secondaryTheme mx-auto mt-6"></div>
    <p class="mt-6 text-lg text-blue-100 max-w-2xl mx-auto px-6">
        Des interventions techniques et expertes pour répondre aux problématiques les plus complexes.
    </p>
    </section>

        <!-- APRES TRAVAUX -->
    <section id="travaux" class="pb-10 pt-4 bg-white md:py-20">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center gap-12">
            <div class="md:w-1/2">
                <div class="inline-block px-4 py-1 rounded-full bg-blue-50 text-primaryTheme font-bold text-sm mb-4 uppercase tracking-wider">Éclat & Finition</div>
                <h2 class="text-3xl font-bold text-gray-800 mb-6 font-title">Remise en état après travaux</h2>
                <p class="text-gray-600 leading-relaxed mb-4 font-bold text-justify">Seule une remise en état professionnelle permet une livraison optimale des espaces.</p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    Nos équipes réalisent l’évacuation des résidus, le décapage des sols, le retrait des voiles de ciment, le lessivage des surfaces et la remise en brillance.
                </p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    Chaque intervention est planifiée et contrôlée pour atteindre un haut niveau de finition.
                </p>
                <div class="bg-gray-50 p-4 border-l-4 border-secondaryTheme italic text-gray-700>">
                    "Des locaux prêts à être exploités immédiatement."
                </div>
            </div>
            <div class="md:w-1/2 h-64 rounded-3xl overflow-hidden shadow-xl">
                <Image 
                    src={travaux}
                    alt="Nettoyage après travaux Proxi'clean"
                    width={800} 
                    height={600}
                    class="w-full h-full object-cover shadow-inner"
                    loading="lazy" 
                />
            </div>
        </div>
    </section>

    <!-- VITRERIE-->
    <section id="vitrerie" class="pb-10 pt-4 bg-gray-50 md:py-20">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row-reverse items-center gap-12">
            <div class="md:w-1/2">
                <div class="inline-block px-4 py-1 rounded-full bg-blue-50 text-primaryTheme font-bold text-sm mb-4 uppercase tracking-wider">Expertise en hauteur</div>
                <h2 class="text-3xl font-bold text-gray-800 mb-6 font-title">Vitrerie toute hauteur</h2>
                <p class="text-gray-600 leading-relaxed mb-4 font-bold text-justify">De la vitrerie de plain-pied aux accès les plus complexes, l’entretien des surfaces vitrées exige technicité, précision et maîtrise du risque.</p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    Proxi’Clean intervient sur l’ensemble de vos vitrages : vitrerie classique, façades, surfaces commerciales, verrières et bâtiments de grande hauteur.
                </p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    Nos équipes habilitées utilisent des méthodes adaptées à chaque configuration (perches carbone, nacelles) afin de garantir un nettoyage performant, en toute sécurité.
                </p>
                <div class="bg-gray-50 p-4 border-l-4 border-secondaryTheme italic text-gray-700">
                    "Des vitres parfaitement entretenues, une luminosité préservée et une image de marque renforcée."
                </div>
            </div>
            <div class="md:w-1/2 h-64 rounded-3xl overflow-hidden shadow-xl">
                <Image 
                    src={vitrerie}
                    alt="Secteur vitrerie Proxi'clean"
                    width={800} 
                    height={600}
                    class="w-full h-full object-cover shadow-inner"
                    loading="lazy" 
                />
            </div>
        </div>
    </section>

    <!-- PANNEAUX SOLAIRES -->
    <section id="panneaux-solaires" class="pb-10 pt-4 bg-white md:py-20">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center gap-12">
            <div class="md:w-1/2">
                <div class="inline-block px-4 py-1 rounded-full bg-blue-50 text-primaryTheme font-bold text-sm mb-4 uppercase tracking-wider">Rendement & Énergie</div>
                <h2 class="text-3xl font-bold text-gray-800 mb-6 font-title">Nettoyage de panneaux solaires</h2>
                <p class="text-gray-600 leading-relaxed mb-4 font-bold text-justify">La propreté des panneaux conditionne directement leur rendement énergétique.</p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    Nous utilisons des techniques non abrasives, de l’eau osmosée et des équipements adaptés pour éliminer dépôts, pollens et particules sans altérer les surfaces.
                </p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    Les interventions sont sécurisées et conformes aux préconisations fabricants.
                </p>
                <div class="bg-gray-50 p-4 border-l-4 border-secondaryTheme italic text-gray-700">
                    "Une production optimisée et des installations préservées."
                </div>
            </div>
            <div class="md:w-1/2 h-64 rounded-3xl overflow-hidden shadow-xl">
                <Image 
                    src={panneaux}
                    alt="Nettoyage panneaux solaires Proxi'clean"
                    width={800} 
                    height={600}
                    class="w-full h-full object-cover shadow-inner"
                    loading="lazy" 
                />
            </div>
        </div>
    </section>

    <!-- POST MORTEM-->
    <section id="post-mortem" class="pb-10 pt-4 bg-gray-50 md:py-20">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row-reverse items-center gap-12">
            <div class="md:w-1/2">
                <div class="inline-block px-4 py-1 rounded-full bg-blue-50 text-primaryTheme font-bold text-sm mb-4 uppercase tracking-wider">Urgence Sanitaire</div>
                <h2 class="text-3xl font-bold text-gray-800 mb-6 font-title">Nettoyage post mortem</h2>
                <p class="text-gray-600 leading-relaxed mb-4 font-bold text-justify">Ces interventions exigent expertise, rigueur et respect absolu des protocoles sanitaires.</p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    Proxi’Clean déploie des procédures strictes incluant <span class="font-bold">la désinfection par ozonation</span>, le traitement des surfaces, l’élimination des agents biologiques et la neutralisation des odeurs persistantes.
                </p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    Nos équipes interviennent avec discrétion, professionnalisme et respect des lieux.
                </p>
                <div class="bg-gray-50 p-4 border-l-4 border-secondaryTheme italic text-gray-700">
                    "Un environnement assaini, sécurisé et traité avec la plus grande rigueur."
                </div>
            </div>
            <div class="md:w-1/2 h-64 rounded-3xl overflow-hidden shadow-xl">
                <Image 
                    src={nuisible}
                    alt="Nettoyage Post Mortem Proxi'clean"
                    width={800} 
                    height={600}
                    class="w-full h-full object-cover shadow-inner"
                    loading="lazy" 
                />
            </div>
        </div>
    </section>

    <!-- DIOGENE -->
    <section id="diogene" class="pb-10 pt-4 bg-white md:py-20">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center gap-12">
            <div class="md:w-1/2">
                <div class="inline-block px-4 py-1 rounded-full bg-blue-50 text-primaryTheme font-bold text-sm mb-4 uppercase tracking-wider">Réhabilitation & Salubrité</div>
                <h2 class="text-3xl font-bold text-gray-800 mb-6 font-title">Nettoyage Diogène</h2>
                <p class="text-gray-600 leading-relaxed mb-4 font-bold text-justify">Chaque situation nécessite une approche méthodique et profondément humaine.</p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    Nous assurons le tri, l’évacuation des encombrants, le nettoyage intensif, la désinfection et le traitement des odeurs afin de restaurer des conditions sanitaires adaptées.
                </p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    Toutes nos interventions sont réalisées dans le respect des occupants et avec une organisation maîtrisée.
                </p>
                <div class="bg-gray-50 p-4 border-l-4 border-secondaryTheme italic text-gray-700">
                    "Des lieux réhabilités et un environnement sain retrouvé."
                </div>
            </div>
                <div class="md:w-1/2 h-64 rounded-3xl overflow-hidden shadow-xl">
                    <Image 
                        src={diogene}
                        alt="Nettoyage Diogène Proxi'clean"
                        width={800} 
                        height={600}
                        class="w-full h-full object-cover shadow-inner"
                        loading="lazy" 
                    />
                </div>
        </div>
    </section>

        <!-- NUISIBLES -->
    <section id="nuisibles" class="pb-10 pt-4 bg-gray-50 md:py-20">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row-reverse items-center gap-12">
            
            <div class="md:w-1/2">
                <div class="flex flex-nowrap items-center gap-2 mb-4 w-full">
                    <div class="whitespace-nowrap px-3 py-1 rounded-full bg-blue-50 text-primaryTheme font-bold text-[10px] sm:text-sm uppercase tracking-wider border border-blue-100">
                        Protection & Élimination
                    </div>
                    
                    <div class="flex md:hidden items-center gap-1 whitespace-nowrap bg-green-100 text-green-700 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider border border-green-200 shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                        </svg>
                        <span class="shrink-0">entreprise Habilitée</span>
                    </div>
                </div>

                <h2 class="text-3xl font-bold text-gray-800 mb-6 font-title">Lutte contre les nuisibles</h2>
                <p class="text-gray-600 leading-relaxed mb-4 font-bold text-justify">Prévenir et traiter les nuisibles est un enjeu sanitaire majeur.</p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    Nous mettons en place des dispositifs de détection, des plans d’actions préventifs et des traitements ciblés, dans le respect des normes en vigueur.
                </p>
                <p class="text-gray-600 leading-relaxed mb-8 text-justify">
                    Le suivi est tracé pour garantir l’efficacité dans la durée.
                </p>

                <div class="bg-gray-100 p-4 border-l-4 border-secondaryTheme italic text-gray-700 mb-8">
                    "Un site protégé, conforme et durablement sécurisé."
                </div>

                <div class="pt-4 border-t border-gray-200">
                    <span class="text-[10px] text-gray-400 uppercase tracking-widest">Certificat N117262</span>
                    <p class="text-xs font-mono text-gray-500">Valide du 12.02.2026 au 12.02.2031</p>
                </div>
            </div>
            
            <div class="md:w-1/2 relative pt-10"> 
                <div class="hidden md:flex absolute top-0 left-0 items-center gap-2 bg-green-100 text-green-700 px-4 py-2 rounded-full text-xs font-bold uppercase tracking-wider border border-green-200 shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    Entreprise Habilitée
                </div>

                <div class="bg-gray-200 h-64 rounded-3xl overflow-hidden shadow-xl">
                    <Image 
                        src={nuisible}
                        alt="Lutte contre les nuisibles Proxi'clean"
                        width={800} 
                        height={600}
                        class="w-full h-full object-cover shadow-inner"
                        loading="lazy" 
                    />
                </div>
            </div>
        </div>
    </section>

    <section class="py-10 text-center bg-gray-50 md:py-20"> 
        <h2 class="text-3xl font-bold mb-8">Confiez vos interventions complexes à des spécialistes</h2>
        <a href="/contact" class="btn btn-lg bg-secondaryTheme text-white border-none hover:scale-105 transition-transform inline-flex items-center gap-2">
            <span>Demander votre devis personnalisé</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
        </a>
    </section>
</Layout>
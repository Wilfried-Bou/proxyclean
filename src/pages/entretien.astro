---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import {Image} from "astro:assets";

import grandeDistribution from "../assets/entretien/gDristibution.jpg";
import tertiaire from "../assets/entretien/tertiaire.jpg";
import dataCenter from "../assets/entretien/dataCenter.jpg";
import industrie from "../assets/entretien/industrie.jpg";
import logistique from "../assets/entretien/logistique.jpg";
---
<Layout title="Entretien Régulier à Toulouse | Proxi'Clean Services" 
        description="Solutions de nettoyage pour l'industrie, la logistique, le tertiaire et la grande distribution à Toulouse et en Occitanie.">
    
    <Breadcrumb currentPage="Entretien régulier"></Breadcrumb>

    <section class="py-16 bg-primaryTheme text-white text-center">
        <h1 class="text-4xl md:text-6xl font-black text-white uppercase leading-tight">
			Entretien <span class="text-secondaryTheme">Regulier</span>
		</h1>
        <div class="w-24 h-1.5 bg-secondaryTheme mx-auto mt-6"></div>
        <p class="mt-6 text-lg text-blue-100 max-w-2xl mx-auto px-6">
            Des protocoles rigoureux pour garantir la performance et l'image de votre entreprise au quotidien.
        </p>
    </section>

    <!-- INDUSTRIE -->
    <section id="industrie" class="py-10 bg-white md:py-20">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center gap-12">
            <div class="md:w-1/2">
                <div class="inline-block px-4 py-1 rounded-full bg-blue-50 text-primaryTheme font-bold text-sm mb-4 uppercase tracking-wider">Sécurité & Performance</div>
                <h2 class="text-3xl font-bold text-gray-800 mb-6 font-title">Industrie</h2>
                <p class="text-gray-600 leading-relaxed mb-4 font-bold text-justify">Un environnement industriel propre est un levier direct de sécurité, de performance et d’image.</p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    <span class="font-bold">Proxi’Clean Services intervient sur les sites industriels en Haute-Garonne et sur l’ensemble de la région Occitanie</span>, avec des protocoles adaptés aux contraintes d’exploitation : gestion des zones sensibles, respect des flux et traçabilité.
                </p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">Nos équipes sont formées aux environnements techniques et appliquent des procédures strictes pour garantir une propreté constante <span class="font-bold"> sur vos installations industrielles</span>, sans perturber votre production.</p>
                <div class="bg-gray-50 p-4 border-l-4 border-secondaryTheme italic text-gray-700">
                    "Un environnement sécurisé pour une qualité de production optimale."
                </div>
            </div>
            <div class="md:w-1/2 h-64 rounded-3xl overflow-hidden shadow-xl">
                <Image 
                    src={industrie}
                    alt="Nettoyage d'une zone de production industrielle à Toulouse par Proxi'Clean"
                    width={800} 
                    height={600}
                    class="w-full h-full object-cover shadow-inner"
                    loading="eager" 
                />
            </div>
        </div>
    </section>

    <!-- LOGISTIQUE -->
    <section id="logistique" class="py-10 bg-gray-50 md:py-20">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row-reverse items-center gap-12">
            <div class="md:w-1/2">
                <div class="inline-block px-4 py-1 rounded-full bg-blue-50 text-primaryTheme font-bold text-sm mb-4 uppercase tracking-wider">Fluidité Opérationnelle</div>
                <h2 class="text-3xl font-bold text-gray-800 mb-6 font-title">Logistique</h2>
                <p class="text-gray-600 leading-relaxed mb-4 font-bold text-justify">
                    Dans les plateformes logistiques, la propreté est une composante essentielle de la fluidité opérationnelle.</p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    Nous adaptons nos interventions à vos cadences et à vos plages d’activité afin de assurer la continuité de vos opérations.
                </p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">Organisation rigoureuse, matériels performants et contrôles qualité réguliers permettent de maintenir un niveau d’exigence élevé, même dans les environnements à forte rotation.</p>
                <div class="bg-white p-4 border-l-4 border-secondaryTheme italic text-gray-700 shadow-sm">
                    "Des espaces fonctionnels, sûrs et parfaitement entretenus."
                </div>
            </div>
            <div class="md:w-1/2 h-64 rounded-3xl overflow-hidden shadow-xl">
                <Image 
                    src={logistique}
                    alt="Entretien régulier d'une plateforme logistique et de stockage en Occitanie"
                    width={800} 
                    height={600}
                    class="w-full h-full object-cover shadow-inner"
                    loading="lazy" 
                />
            </div>
        </div>
    </section>

        <!-- TERTIAIRE-->
    <section id="tertiaire" class="py-10 bg-white md:py-20">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center gap-12">
            <div class="md:w-1/2">
                <div class="inline-block px-4 py-1 rounded-full bg-blue-50 text-primaryTheme font-bold text-sm mb-4 uppercase tracking-wider">Confort & Image de marque</div>
                <h2 class="text-3xl font-bold text-gray-800 mb-6 font-title">Tertiaire</h2>
                <p class="text-gray-600 leading-relaxed mb-4 font-bold text-justify">Vos locaux reflètent votre image auprès de vos collaborateurs et visiteurs.</p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    <span class="font-bold">Proxi’Clean Services intervient auprès des entreprises du secteur tertiaire à Toulouse et sur l’ensemble de la Haute-Garonne</span>, en déployant une méthode d’entretien précise pour garantir confort, hygiène et qualité perçue au quotidien.
                </p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">Chaque prestation est pilotée pour assurer régularité et discrétion, avec un suivi mesurable grâce à notre démarche qualité.</p>
                <div class="bg-gray-50 p-4 border-l-4 border-secondaryTheme italic text-gray-700">
                    "Des espaces accueillants et une expérience professionnelle valorisée."
                </div>
            </div>
            <div class="md:w-1/2 h-64 rounded-3xl overflow-hidden shadow-xl">
                <Image 
                    src={tertiaire}
                    alt="Nettoyage et aspiration de bureaux open-space dans un immeuble tertiaire à Toulouse"
                    width={800} 
                    height={600}
                    class="w-full h-full object-cover shadow-inner"
                    loading="lazy" 
                />
            </div>
        </div>
    </section>

        <!-- DISTRIBUTION -->
    <section id="distribution" class="py-10 bg-gray-50 md:py-20">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row-reverse items-center gap-12">
            <div class="md:w-1/2">
                <div class="inline-block px-4 py-1 rounded-full bg-blue-50 text-primaryTheme font-bold text-sm mb-4 uppercase tracking-wider">Flux & Propreté constante</div>
                <h2 class="text-3xl font-bold text-gray-800 mb-6 font-title">Grande Distribution</h2>
                <p class="text-gray-600 leading-relaxed mb-4 font-bold text-justify">
                    La propreté participe directement à l’expérience client et à la performance commerciale.</p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    Nos équipes interviennent avec réactivité et méthode pour maintenir des surfaces irréprochables, même en période de forte affluence.
                </p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">Nous intégrons les contraintes horaires, les normes d’hygiène et les impératifs d’image propres au secteur.</p>
                <div class="bg-white p-4 border-l-4 border-secondaryTheme italic text-gray-700 shadow-sm">
                    "Un point de vente attractif, sécurisé et conforme aux  standards du secteur."
                </div>
            </div>
            <div class="md:w-1/2 h-64 rounded-3xl overflow-hidden shadow-xl">
                <Image 
                    src={grandeDistribution}
                    alt="Entretien des sols d'un supermarché de la grande distribution à Toulouse avant ouverture"
                    width={800} 
                    height={600}
                    class="w-full h-full object-cover shadow-inner"
                    loading="lazy" 
                />
            </div>
        </div>
    </section>

            <!-- DATA CENTER-->
    <section id="data" class="py-10 bg-white md:py-20">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center gap-12">
            <div class="md:w-1/2">
                <div class="inline-block px-4 py-1 rounded-full bg-blue-50 text-primaryTheme font-bold text-sm mb-4 uppercase tracking-wider">Milieu Critique & Haute Précision</div>
                <h2 class="text-3xl font-bold text-gray-800 mb-6 font-title">Data Center</h2>
                <p class="text-gray-600 leading-relaxed mb-4 font-bold text-justify">Dans un data center, la propreté est une exigence technique critique.</p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">
                    Nous appliquons des protocoles spécifiques : dépoussiérage technique, nettoyage des planchers surélevés, intervention en zones sensibles et limitation stricte des particules.
                </p>
                <p class="text-gray-600 leading-relaxed mb-4 text-justify">Nos équipes interviennent selon des procédures sécurisées, sans compromettre vos infrastructures.</p>
                <div class="bg-gray-50 p-4 border-l-4 border-secondaryTheme italic text-gray-700">
                    "Un environnement contrôlé qui protège vos équipements stratégiques."
                </div>
            </div>
            <div class="md:w-1/2 h-64 rounded-3xl overflow-hidden shadow-xl">
                <Image 
                    src={dataCenter}
                    alt="Nettoyage technique de haute précision dans une salle blanche de Data Center à Toulouse"
                    width={800} 
                    height={600}
                    class="w-full h-full object-cover shadow-inner"
                    loading="lazy" 
                />
            </div>
        </div>
    </section>

    <section class="py-20 text-center bg-gray-50"> 
        <h2 class="text-3xl font-bold mb-8">Prêt à mettre en place votre plan d'entretien régulier ?</h2>
        <p class="text-gray-600 mb-8 max-w-xl mx-auto">
            Nos agents interviennent quotidiennement sur <strong>Toulouse</strong>, 
            <strong>Blagnac</strong>, <strong>Labège</strong> et sur l'ensemble de la région <strong>Occitanie</strong>.
        </p>
        <a href="/contact" class="btn btn-lg bg-secondaryTheme text-white border-none hover:scale-105 transition-transform inline-flex items-center gap-2">
            <span>Demander votre devis personnalisé</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
        </a>
    </section>
</Layout>
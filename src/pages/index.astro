							</a>
						</li>

						<li class="group flex items-center gap-4">
							<div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-secondaryTheme/10 transition-colors">
								<img src="/tertiaire.png" class="w-16 h-16" alt="Icon Tertiaire" />
							</div>
							<a href="/entretien#tertiaire" class="font-semibold text-gray-700 group-hover:text-secondaryTheme transition-colors">
								Tertiaire
							</a>
						</li>

						<li class="group flex items-center gap-4">
							<div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-secondaryTheme/10 transition-colors">
								<img src="/gDistribution.png" class="w-16 h-16" alt="Icon Distribution" />
							</div>
							<a href="/entretien#distribution" class="font-semibold text-gray-700 group-hover:text-secondaryTheme transition-colors">
								Grande distribution
							</a>
						</li>

						<li class="group flex items-center gap-4">
							<div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-secondaryTheme/10 transition-colors">

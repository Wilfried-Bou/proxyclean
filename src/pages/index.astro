---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import {Image} from "astro:assets";

import logo from '../assets/logo2.png';
import picto1 from '../assets/vision/1pouce.png';
import picto2 from '../assets/vision/2index.png';
import picto3 from '../assets/vision/3majeur.png';
import picto4 from '../assets/vision/4annulaire.png';
import picto5 from '../assets/vision/5auriculaire.png';
---
<Layout>
	<Breadcrumb ></Breadcrumb>
	<section class="relative bg-theme py-6 px-6 overflow-hidden">
		<div class="absolute top-0 right-0 w-64 h-64 bg-secondaryTheme rounded-full blur-3xl opacity-20 -mr-32 -mt-32"></div>
		
		<div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-12 relative z-10">
			<div class="flex-1 text-center md:text-left">
				<h1 class="text-4xl md:text-6xl font-black text-white uppercase leading-tight">
					Le service<br/> <span class="text-secondaryTheme">autrement</span>
				</h1>
				<p class="mt-6 text-blue-100 text-lg max-w-lg">
					Solutions de propreté, prestations techniques et services associés pour environnements exigeants.
				</p>
				<!-- <div class="mt-10 flex flex-wrap gap-4 justify-center md:justify-start">
					<a href="/contact" class="btn bg-[#003A9A] hover:bg-[#052A6E] text-white border-none px-8">
						Contactez-nous
					</a>
				</div> -->
			</div>

			<div class="flex-1 flex justify-center md:justify-end">
				<div class="bg-white p-8 md:p-12 rounded-2xl shadow-2xl over:scale-105 cursor-default">
					<Image 
						src={logo}
						alt="Logo proxi'clean"
						width={250}
						height={250}
						class="w-full h-full object-cover"
						loading="eager" 
					/>
				</div>
			</div>
		</div>
	</section>

	<section id="qui-sommes-nous" class="bg-white m-8">
		<div class="max-w-4xl mx-auto text-center ">
			<h2 class="text-3xl font-bold text-theme uppercase tracking-wider">Qui sommes-nous?</h2>
			<div class="w-20 h-1.5 bg-secondaryTheme mx-auto mt-4 mb-12"></div>
			<h3 class="text-lg font-semibold mb-4">
				Une vision moderne des services de nettoyage.
			</h3>
			<div class="text-gray-700 space-y-4">
				<p>Proxi'clean services, accompagne les professionnels avec une exigence élevée de qualité, de fiabilité et de réactivité.</p>
				<p>Notre approche repose sur une organisation claire, des équipes spécialisées et une parfaite maitrise des environnements techniques.</p>
				<p>Chaque prestation est conçue comme une solution sur mesure, adaptée aux contraintes réelles de nos clients, avec un objectif constant : </p>
				<p class="font-bold">Proposer un service différent.</p>
			</div>
		</div>
	</section>

	<section id="vision" class="bg-primaryTheme mt-16 p-12">
		<div class="max-w-6xl mx-auto text-center">
            <h2 class="text-3xl font-bold text-white uppercase tracking-wider">Notre vision</h2>
            <div class="w-20 h-1.5 bg-secondaryTheme mx-auto mt-4 mb-12"></div>
			
            <h3 class="text-lg text-white font-semibold mb-8">Les 5 piliers <span class="uppercase">Proxi'Clean services</span></h3>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
                <div class="bg-white p-6 rounded-xl shadow-sm border-b-4 border-primaryTheme cursor-default flex flex-col h-full">
                    <div class="text-secondaryTheme mb-4 flex justify-center">
                        <Image 
							src={picto1}
							alt="Pictograme pouce"
							width="200"
							height="200"
							class="w-24 h-24 md:w-32 md:h-32 object-contain mx-auto"
							loading="lazy" 
						/>
                    </div>
                    <h3 class="font-bold text-theme leading-tight min-h-[3rem] flex items-center justify-center">Votre coup de pouce</h3>
                    <p class="text-sm text-gray-500 mt-2">Des agents formés et encadrés, des consignes claires, des contrôles réguliers.</p>
					<p class="text-sm text-gray-700 font-bold mt-auto pt-4"> Vous gagnez du temps. Nous sécurisons votre niveau de propreté.</p>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-sm border-b-4 border-primaryTheme cursor-default flex flex-col h-full">
                    <div class="text-secondaryTheme mb-4 flex justify-center">
                        <Image 
							src={picto2}
							alt="Pictograme index"
							width="200"
							height="200"
							class="w-24 h-24 md:w-32 md:h-32 object-contain mx-auto"
							loading="lazy" 
						/>
                    </div>
                    <h3 class="font-bold text-theme leading-tight font-bold text-theme leading-tight min-h-[3rem] flex items-center justify-center">Une direction claire</h3>
                    <p class="text-sm text-gray-500 mt-2">Une organisation structurée, des engagements écrits et des procédures claires.</p>
					<p class="text-sm text-gray-700 font-bold mt-2 text-sm text-gray-700 font-bold mt-auto pt-4">Des prestations maîtrisées.</p>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-sm border-b-4 border-primaryTheme cursor-default flex flex-col h-full">
                    <div class="text-secondaryTheme mb-4 flex justify-center">
                        <Image 
							src={picto3}
							alt="Pictograme majeur"
							width="200"
							height="200"
							class="w-24 h-24 md:w-32 md:h-32 object-contain mx-auto"
							loading="lazy" 
						/>
                    </div>
                    <h3 class="font-bold text-theme leading-tight font-bold text-theme leading-tight min-h-[3rem] flex items-center justify-center">Votre satisfaction</h3>
                    <p class="text-sm text-gray-500 mt-2">Vos contraintes, votre réalité terrain, vos priorités.</p>
					<p class="text-sm text-gray-700 font-bold mt-2 text-sm text-gray-700 font-bold mt-auto pt-4">Chaque prestation s'adapte à votre site.</p>

                </div>

                <div class="bg-white p-6 rounded-xl shadow-sm border-b-4 border-primaryTheme cursor-default flex flex-col h-full">
                    <div class="text-secondaryTheme mb-4 flex justify-center">
                        <Image 
							src={picto4}
							alt="Pictograme annulaire"
							width="200"
							height="200"
							class="w-24 h-24 md:w-32 md:h-32 object-contain mx-auto"
							loading="lazy" 
						/>
                    </div>
                    <h3 class="font-bold text-theme leading-tight font-bold text-theme leading-tight min-h-[3rem] flex items-center justify-center">Des partenaires engagés</h3>
                    <p class="text-sm text-gray-500 mt-2">Des fournisseurs fiables et réactifs, des solutions adaptées.</p>
					<br>
					<p class="text-sm text-gray-700 font-bold mt-2 text-sm text-gray-700 font-bold mt-auto pt-4">Une continuité de service assurée.</p>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-sm border-b-4 border-primaryTheme cursor-default flex flex-col h-full">
                    <div class="text-secondaryTheme mb-4 flex justify-center">
                        <Image 
							src={picto5}
							alt="Pictograme auriculaire"
							width="200"
							height="200"
							class="w-24 h-24 md:w-32 md:h-32 object-contain mx-auto"
							loading="lazy" 
						/>
                    </div>
                    <h3 class="font-bold text-theme leading-tight font-bold text-theme leading-tight min-h-[3rem] flex items-center justify-center">Le suivi et traçabilité</h3>
                    <p class="text-sm text-gray-500 mt-2">Suivi des prestations, contrôles qualité tracés, indicateurs partagés.</p>
					<p class="text-sm text-gray-700 font-bold mt-auto pt-4">Une propreté mesurée, des performances suivies et la garantie d’un service conforme à vos attentes.</p>
                </div>
            </div>
			<!-- <p class="text-lg text-white font-semibold mt-8">Notre méthode pour une propreté maîtrisée</p> -->
        </div>
	</section>

	<section id="services" class="bg-white m-16">
		<div class="max-w-6xl mx-auto text-center">
		<h2 class="text-3xl font-bold text-theme uppercase tracking-wider">Nos Solutions</h2>
		<div class="w-20 h-1.5 bg-secondaryTheme mx-auto mt-4 mb-12"></div>
		
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<div class="p-8 rounded-xl bg-white border border-gray-100 shadow-sm hover:shadow-md transition-shadow border-t-4 border-t-primaryTheme cursor-default">
					<div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-6 mx-auto">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-secondaryTheme" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 16l2 2 4-4" />
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-800 mb-3">
						<a href="/entretien" class="hover:text-secondaryTheme hover:underline transition-colors">Entretien régulier</a>
					</h3>

						<ul class="text-gray-600 space-y-4 w-full flex flex-col items-center md:items-center">

							<li class="flex flex-col items-center md:flex-row md:items-start gap-2 md:gap-3 text-center md:text-left w-full md:max-w-fit">
								<span class="hidden md:block w-1.5 h-1.5 rounded-full bg-secondaryTheme shrink-0 mt-2"></span>
								<a href="/entretien#industrie" class="hover:text-secondaryTheme hover:underline transition-colors">
									Industrie
								</a>
							</li>

							<li class="flex flex-col items-center md:flex-row md:items-start gap-2 md:gap-3 text-center md:text-left w-full md:max-w-fit">
								<span class="hidden md:block w-1.5 h-1.5 rounded-full bg-secondaryTheme shrink-0 mt-2"></span>
								<a href="/entretien#logistique" class="hover:text-secondaryTheme hover:underline transition-colors">
									Logistique
								</a>
							</li>
							
							<li class="flex flex-col items-center md:flex-row md:items-start gap-2 md:gap-3 text-center md:text-left w-full md:max-w-fit">
								<span class="hidden md:block w-1.5 h-1.5 rounded-full bg-secondaryTheme shrink-0 mt-2"></span>
								<a href="/entretien#tertiaire" class="hover:text-secondaryTheme hover:underline transition-colors">
									Tertiaire
								</a>
							</li>
							
							<li class="flex flex-col items-center md:flex-row md:items-start gap-2 md:gap-3 text-center md:text-left w-full md:max-w-fit">
								<span class="hidden md:block w-1.5 h-1.5 rounded-full bg-secondaryTheme shrink-0 mt-2"></span>
								<a href="/entretien#distribution" class="hover:text-secondaryTheme hover:underline transition-colors">
									Grande distribution
								</a>	
							</li>
							
							<li class="flex flex-col items-center md:flex-row md:items-start gap-2 md:gap-3 text-center md:text-left w-full md:max-w-fit">
								<span class="hidden md:block w-1.5 h-1.5 rounded-full bg-secondaryTheme shrink-0 mt-2"></span>
								<a href="/entretien#data" class="hover:text-secondaryTheme hover:underline transition-colors">
									Data center
								</a>
							</li>
						</ul>

					<!-- <ul class="text-gray-600 space-y-4 px-4 md:pl-16 flex flex-col w-full max-w-md mx-auto">
						<li class="group flex items-center gap-4">
							<div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-secondaryTheme/10 transition-colors">
								<img src="/industrie.png" class="w-16 h-16" alt="Icon Industrie" />
							</div>
							<a href="/entretien#industrie" class="font-semibold text-gray-700 group-hover:text-secondaryTheme transition-colors">
								Industrie
							</a>
						</li>

						<li class="group flex items-center gap-4">
							<div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-secondaryTheme/10 transition-colors">

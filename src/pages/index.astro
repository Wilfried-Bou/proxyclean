						<li class="flex flex-col items-center md:flex-row md:items-start gap-2 md:gap-3 text-center md:text-left w-full md:max-w-fit">
							<span class="hidden md:block w-1.5 h-1.5 rounded-full bg-secondaryTheme shrink-0 mt-2"></span>
							<a href="/specifique#diogene" class="hover:text-secondaryTheme hover:underline transition-colors">
								Nettoyage Diogène

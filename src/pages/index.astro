							</div>
							<a href="/entretien#data" class="font-semibold text-gray-700 group-hover:text-secondaryTheme transition-colors">
								Data center
							</a>
						</li>
					</ul> -->
				</div>

				<div class="p-8 rounded-xl bg-white border border-gray-100 shadow-sm hover:shadow-md transition-shadow border-t-4 border-t-primaryTheme cursor-default">
					<div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-6 mx-auto">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-secondaryTheme" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.618.309a2 2 0 01-1.789 0l-.618-.309a6 6 0 00-3.86-.517l-2.387.477a2 2 0 00-1.022.547l-1.16 1.16a2 2 0 00.442 3.066L3 21h18l-.574-.506a2 2 0 00.442-3.066l-1.16-1.16z" />
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11V3m0 0L9 6m3-3l3 3" />
						</svg>
					</div> 
					<h3 class="text-xl font-bold text-gray-800 mb-3">
						<a href="/specifique" class="hover:text-secondaryTheme hover:underline transition-colors">Prestations spécifiques</a>
					</h3>

					<ul class="text-gray-600 space-y-4 w-full flex flex-col items-center md:items-center">

						<li class="flex flex-col items-center md:flex-row md:items-start gap-2 md:gap-3 text-center md:text-left w-full md:max-w-fit">
							<span class="hidden md:block w-1.5 h-1.5 rounded-full bg-secondaryTheme shrink-0 mt-2"></span>

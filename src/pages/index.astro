							<a href="/specifique#panneaux-solaires" class="hover:text-secondaryTheme hover:underline transition-colors">
								Panneaux solaires
							</a>
						</li>
						<li class="flex flex-col items-center md:flex-row md:items-start gap-2 md:gap-3 text-center md:text-left w-full md:max-w-fit">
							<span class="hidden md:block w-1.5 h-1.5 rounded-full bg-secondaryTheme shrink-0 mt-2"></span>
							<a href="/specifique#post-mortem" class="hover:text-secondaryTheme hover:underline transition-colors">
